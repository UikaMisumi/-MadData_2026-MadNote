# Frontend (Vercel build-time)
VITE_API_URL=https://your-render-service.onrender.com/api/v1

# Backend (Render runtime)
# Comma-separated exact origins (optional; localhost defaults already included)
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com

# For cross-site cookies between vercel.app and onrender.com:
COOKIE_SAMESITE=none
COOKIE_SECURE=true

# Chat backend key
DEEPSEEK_API_KEY=
